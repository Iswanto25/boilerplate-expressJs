{
	"name": "boilerplate-expressjs",
	"version": "1.0.0",
	"description": "",
	"main": "app.ts",
	"type": "module",
	"scripts": {
		"prettier": "prettier . --write",
		"lint": "eslint \"src/**/*.ts\" \"__tests__/**/*.ts\" \"prisma/**/*.ts\" \"prisma.config.ts\"",
		"typecheck": "tsc --noEmit",
		"lint:fix": "eslint \"src/**/*.ts\" \"__tests__/**/*.ts\" \"prisma/**/*.ts\" \"prisma.config.ts\" --fix",
		"pretest": "node scripts/prepare-test-env.cjs",
		"start": "node dist/src/app.js",
		"dev": "tsx watch src/dev.ts",
		"worker:dev": "tsx watch src/worker.ts",
		"worker:start": "node dist/src/worker.js",
		"start:migrate": "prisma migrate deploy && npm run start",
		"build": "tsc && tsc-alias",
		"test": "node --import tsx/esm --import ./scripts/test-loader.mjs --experimental-test-module-mocks --test '__tests__/**/*.test.ts'",
		"test:integration": "node --import tsx/esm --import ./scripts/test-loader.mjs --experimental-test-module-mocks --test '__tests__/integration/*.test.ts'",
		"generate-api-key": "tsx scripts/generateApiKey.ts",
		"generate-data": "tsx src/utils/generateData.ts",
		"seed": "npx prisma db seed"
	},
	"author": "",
	"license": "ISC",
	"engines": {
		"node": ">=24.0.0"
	},
	"prisma": {
		"seed": "tsx prisma/seed.ts"
	},
	"dependencies": {
		"@aws-sdk/client-s3": "^3.917.0",
		"@aws-sdk/s3-request-presigner": "^3.917.0",
		"@prisma/adapter-pg": "7.4.2",
		"@prisma/client": "7.4.2",
		"bcrypt": "^6.0.0",
		"bullmq": "^5.76.6",
		"compression": "^1.8.1",
		"cors": "^2.8.5",
		"dotenv": "^17.2.3",
		"express": "^5.1.0",
		"helmet": "^8.1.0",
		"ioredis": "^5.8.2",
		"jsonwebtoken": "^9.0.2",
		"multer": "^2.0.2",
		"nodemailer": "^9.0.3",
		"pg": "^8.19.0",
		"pino": "^10.1.0",
		"pino-pretty": "^13.1.2",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@faker-js/faker": "^8.4.1",
		"@types/bcrypt": "^6.0.0",
		"@types/compression": "^1.8.1",
		"@types/cors": "^2.8.19",
		"@types/express": "^5.0.4",
		"@types/jsonwebtoken": "^9.0.10",
		"@types/multer": "^2.0.0",
		"@types/node": "^24.13.3",
		"@types/nodemailer": "^7.0.11",
		"@types/pg": "^8.18.0",
		"@types/supertest": "^6.0.3",
		"eslint": "^9.39.1",
		"prettier": "^3.8.3",
		"prisma": "^7.9.0",
		"supertest": "^7.2.2",
		"tsc-alias": "^1.8.16",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.56.1"
	},
	"testScenarios": {
		"utils": [
			"Encryption utilities encrypt and decrypt payloads using DATA_ENCRYPTION_KEY.",
			"Generic utility helpers (strings, passwords, OTP, validation) behave deterministically under controlled randomness.",
			"JWT utilities sign and verify access/refresh tokens with provided secrets.",
			"Response helpers log payloads and format JSON responses when dependencies succeed or fail.",
			"Rate limiter middleware enforces request windows and handles Redis errors gracefully.",
			"S3 helpers validate inputs, upload/delete objects, and surface S3 Storage configuration errors.",
			"SMTP helper builds transporter configuration and propagates send failures.",
			"Token store persists, loads, and deletes tokens using Redis."
		]
	}
}
